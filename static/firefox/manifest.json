{
  "manifest_version": 3,
  "name": "Downlove",
  "description": "Download a Lovable.dev project as a ZIP",
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "github@lw.mozmail.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "icons": {
    "16": "icon_16.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://lovable.dev/*"],
      "run_at": "document_idle",
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon_16.png",
      "48": "icon_48.png"
    }
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://lovable.dev/*",
    "https://api.lovable.dev/*"
  ]
}
